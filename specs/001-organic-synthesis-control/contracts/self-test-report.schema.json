{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.spec/self-test-report.schema.json",
  "title": "SelfTestReport",
  "type": "object",
  "required": ["schemaVersion", "runId", "startedAt", "endedAt", "overallPass", "items"],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "runId": { "type": "string", "minLength": 1 },
    "startedAt": { "type": "string", "format": "date-time" },
    "endedAt": { "type": "string", "format": "date-time" },
    "overallPass": { "type": "boolean" },
    "items": {
      "type": "array",
      "minItems": 6,
      "maxItems": 6,
      "items": {
        "type": "object",
        "required": ["stepId", "status", "message"],
        "properties": {
          "stepId": {
            "type": "string",
            "enum": [
              "Network",
              "DiskSpace",
              "PumpInit",
              "RotaryValveInit",
              "StepperHome",
              "ChillerComm"
            ]
          },
          "status": {
            "type": "string",
            "enum": ["passed", "failed", "not_run"]
          },
          "message": { "type": "string" },
          "durationMs": { "type": "integer", "minimum": 0 }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
